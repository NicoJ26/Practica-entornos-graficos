    OPERADORES
        = : asignación
        * : multiplicación
        += : suma y asignación
        ++ : incremento (++$d preincremento, $d++ postincremento)
        ?: : operador ternario condicional
        , en echo : separa múltiples parámetros de salida
        
    FUNCIONES Y PARAMETROS
        function doble($i)
            Parametro: $i
        
        gettype($variable)
            Parametro: $variable

        is_int($d)
            Parametro: $d
        
        is_string($a)
            Parametro: $a
    
    ESTRUCTURAS DE CONTROL
        if (is_int($d)) { $d += 4; }
        if (is_string($a)) { echo "Cadena: $a"; }
        $d = $a ? ++$d : $d*3;
        Ternario: si $a es verdadero, usa ++$d; si no, usa $d*3

